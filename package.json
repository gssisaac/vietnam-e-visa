{
  "name": "vietnam-e-visa-autofill",
  "version": "1.0.0",
  "description": "Chrome extension that auto-fills the Vietnam e-Visa application form from a YAML profile",
  "type": "module",
  "license": "MIT",
  "author": "Isaac Chaneel Lee <gssisaac@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gssisaac/vietnam-e-visa.git"
  },
  "bugs": {
    "url": "https://github.com/gssisaac/vietnam-e-visa/issues"
  },
  "homepage": "https://github.com/gssisaac/vietnam-e-visa#readme",
  "keywords": [
    "vietnam",
    "e-visa",
    "visa",
    "chrome-extension",
    "autofill",
    "yaml",
    "evisa.gov.vn"
  ],
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.1.2",
  "scripts": {
